# === Base de Données ===
DATABASE_URL=sqlite+aiosqlite:///./simulegal.db

# === Sécurité ===
SECRET_KEY=change_this_to_a_secure_random_string_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# === Paiement (Stripe) ===
# Clé secrète Stripe (commence par sk_test_ ou sk_live_)
STRIPE_SECRET_KEY=sk_test_...
DOMAIN=http://localhost:8001

# === Email (SMTP) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=noreply@simulegal.fr

# === WhatsApp (Twilio) ===
# Récupérez ces infos sur console.twilio.com
TWILIO_SID=AC...
TWILIO_AUTH_TOKEN=...
# Numéro WhatsApp Sandbox (ex: +14155238886)
TWILIO_PHONE=+14155238886

# === Sentry (Monitoring) ===
SENTRY_DSN=

# === Administration ===
REPORT_PRICE=9.99
APP_URL=http://localhost:8001
